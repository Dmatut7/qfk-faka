{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/commerce/**",
              "components/console/**",
              "components/core/**",
              "ui_kits/admin/**",
              "ui_kits/merchant/**",
              "ui_kits/storefront/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope|Noto Sans SC|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Manrope, Noto Sans SC, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|solid|dot|icon|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, solid, dot, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|brand|success|pending|danger|secure)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'brand' | 'success' | 'pending' | 'danger' | 'secure'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|loading|iconLeft|iconRight|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, loading, iconLeft, iconRight, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|neutral|ghost|danger|success)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'neutral' | 'ghost' | 'danger' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:pad|interactive|elevation|as|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: pad, interactive, elevation, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='elevation'] > Literal[value!=/^(?:flat|sm|raised)$/]",
        "message": "<Card> elevation must be one of 'flat' | 'sm' | 'raised'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CardKey'] > JSXAttribute > JSXIdentifier[name!=/^(?:code|label|index|locked|lockedHint|onCopy|key|ref|className|style|children)$/]",
        "message": "<CardKey> doesn't accept that prop. Declared props: code, label, index, locked, lockedHint, onCopy."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckoutSteps'] > JSXAttribute > JSXIdentifier[name!=/^(?:steps|current|className|key|ref|className|style|children)$/]",
        "message": "<CheckoutSteps> doesn't accept that prop. Declared props: steps, current, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConsoleNavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|icon|key|ref|className|style|children)$/]",
        "message": "<ConsoleNavItem> doesn't accept that prop. Declared props: key, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|title|render|align|width|key|ref|className|style|children)$/]",
        "message": "<DataTableColumn> doesn't accept that prop. Declared props: key, title, render, align, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<DataTableColumn> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|required|icon|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, required, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='OrderStatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|solid|label|key|ref|className|style|children)$/]",
        "message": "<OrderStatusBadge> doesn't accept that prop. Declared props: status, solid, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='OrderStatusBadge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:pending|paid|delivered|failed|refunded|closed)$/]",
        "message": "<OrderStatusBadge> status must be one of 'pending' | 'paid' | 'delivered' | 'failed' | 'refunded' | 'closed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|actions|children|padded|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, subtitle, actions, children, padded."
      },
      {
        "selector": "JSXOpeningElement[name.name='PaymentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|desc|icon|tag|selected|onSelect|key|ref|className|style|children)$/]",
        "message": "<PaymentOption> doesn't accept that prop. Declared props: name, desc, icon, tag, selected, onSelect."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: tone, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|brand|success|pending|danger|secure)$/]",
        "message": "<Pill> tone must be one of 'neutral' | 'brand' | 'success' | 'pending' | 'danger' | 'secure'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:amount|original|currency|size|tone|key|ref|className|style|children)$/]",
        "message": "<PriceTag> doesn't accept that prop. Declared props: amount, original, currency, size, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceTag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<PriceTag> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceTag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|neutral)$/]",
        "message": "<PriceTag> tone must be one of 'accent' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|subtitle|price|original|priceLabel|stock|image|thumb|category|typeLabel|promo|tags|sold|onCart|onClick|key|ref|className|style|children)$/]",
        "message": "<ProductCard> doesn't accept that prop. Declared props: name, subtitle, price, original, priceLabel, stock, image, thumb, category, typeLabel, promo, tags, sold, onCart, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductListItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|desc|price|original|stock|thumb|category|date|onClick|key|ref|className|style|children)$/]",
        "message": "<ProductListItem> doesn't accept that prop. Declared props: name, desc, price, original, stock, thumb, category, date, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuantityStepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|min|max|size|onChange|className|key|ref|className|style|children)$/]",
        "message": "<QuantityStepper> doesn't accept that prop. Declared props: value, min, max, size, onChange, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuantityStepper'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<QuantityStepper> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|icon|tone|sub|filled|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, icon, tone, sub, filled."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|success|pending|secure|danger|neutral)$/]",
        "message": "<StatCard> tone must be one of 'brand' | 'success' | 'pending' | 'secure' | 'danger' | 'neutral'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
