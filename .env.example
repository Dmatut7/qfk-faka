# 复制为 .env 并按本机修改。.env 已被 git 忽略,切勿提交真实密钥。
APP_DEBUG = true

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

[DATABASE]
TYPE = mysql
HOSTNAME = localhost
DATABASE = qfk
USERNAME = root
PASSWORD =
HOSTPORT = 3306
# 本地用 unix socket 时填写(否则留空走 TCP)
SOCKET = /tmp/mysql.sock
CHARSET = utf8mb4
PREFIX =

[LANG]
default_lang = zh-cn

# 资源下载防盗链签名密钥:生产环境必填(否则 DownloadService 拒绝签发下载链)。
# 留空时仅在 app_debug=true 的本地/测试可用,生产务必设置一个高强度随机串。
# DOWNLOAD_SECRET = change-me-to-a-long-random-string
